  "body": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\n  <tbody>\n\n   <tr>\n           <td style=\"padding:0;\" bgcolor=\"#f5f1ec\">\n             <table width=\"100%\" style=\"border-spacing:0;\" role=\"presentation\">\n               <tr>\n                 <td bgcolor=\"#f5f1ec\" align=\"center\" style=\"padding: 16px 16px 0px 16px;\">\n                   <a href=\"https://www.bedfordfineartgallery.com/\" target=\"_blank\">\n                     <img src=\"https://res.cloudinary.com/dg6smdedp/image/upload/mailers/img/mailer_header24_2.jpg\" alt=\"Bedford Fine Art Gallery - Unique Art Insight\" style=\"width: 100%; height: auto; max-width: 660px;display: block; vertical-align:top;border:1px solid #222;\">\n                   </a>\n                 </td>\n\t\t\t\n               </tr>\n             </table>\n           </td>\n         </tr>\n\t\t   \n\t\t   \n\t\t   \n\t\t \t<tr>\n           <td width=\"100%\" align=\"center\" bgcolor=\"#fff\" class=\"column\" style=\"padding: 32px 0px 32px 0px;\">\n             <table width=\"90%\" class=\"content\" style=\"border-spacing:0;font-size:15px;font-weight:bold;text-align:center;\" role=\"presentation\">\n               <tr>\n                 <td style=\"padding:16px 10px 16px 10px; border-top: 1px solid #ccc; border-bottom: 1px solid #ccc;\">\n                  <p style=\"font-size: 16px; line-height: 22px; Margin: 0;\">It took Joan and I quite a number of years until we found contemporary fine art that is of the same quality as our 19th century collection.  These contemporary artists became friends and their work is amazing.</p>\n\t\t\t\t\t\n                 </td>\n               </tr>\n             </table>\n           </td>\n         </tr>\n\t\t   \n\t\t   \n\t\t   \n\t\t \n\t\t<tr>\n           <td width=\"100%\" align=\"center\" bgcolor=\"#fff\" class=\"column\" style=\"padding: 0px 0px 0px 0px;\">\n             <table width=\"100%\" class=\"content\" style=\"border-spacing:0;font-size:1